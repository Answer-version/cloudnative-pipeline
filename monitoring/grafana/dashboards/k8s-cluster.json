{
  "dashboard": {
    "title": "Kubernetes Cluster Overview",
    "uid": "k8s-cluster-overview",
    "version": 1,
    "timezone": "browser",
    "schemaVersion": 38,
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Cluster CPU Usage",
        "type": "gauge",
        "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "1 - (sum(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) / sum(rate(node_cpu_seconds_total[5m])))",
            "legendFormat": "CPU Usage",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 0.7 },
                { "color": "red", "value": 0.85 }
              ]
            },
            "max": 1
          }
        }
      },
      {
        "id": 2,
        "title": "Cluster Memory Usage",
        "type": "gauge",
        "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
        "targets": [
          {
            "expr": "1 - (sum(node_memory_MemAvailable_bytes) / sum(node_memory_MemTotal_bytes))",
            "legendFormat": "Memory Usage",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 0.7 },
                { "color": "red", "value": 0.85 }
              ]
            },
            "max": 1
          }
        }
      },
      {
        "id": 3,
        "title": "Node Count",
        "type": "stat",
        "gridPos": { "h": 6, "w": 4, "x": 16, "y": 0 },
        "targets": [
          {
            "expr": "count(kube_node_info)",
            "legendFormat": "Nodes",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "blue", "value": null }
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Pod Count by Status",
        "type": "piechart",
        "gridPos": { "h": 6, "w": 8, "x": 0, "y": 6 },
        "targets": [
          {
            "expr": "sum(kube_pod_status_phase) by (phase)",
            "legendFormat": "{{ phase }}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 5,
        "title": "Deployment Status",
        "type": "table",
        "gridPos": { "h": 6, "w": 8, "x": 8, "y": 6 },
        "targets": [
          {
            "expr": "kube_deployment_status_replicas_available",
            "legendFormat": "{{ deployment }}",
            "refId": "A"
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": { "Time": true, "Value": false },
              "indexByName": {},
              "renameByName": {}
            }
          }
        ]
      },
      {
        "id": 6,
        "title": "Service Status",
        "type": "table",
        "gridPos": { "h": 6, "w": 8, "x": 16, "y": 6 },
        "targets": [
          {
            "expr": "kube_service_info",
            "legendFormat": "{{ service }} - {{ namespace }}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 7,
        "title": "Storage Usage",
        "type": "gauge",
        "gridPos": { "h": 6, "w": 12, "x": 0, "y": 12 },
        "targets": [
          {
            "expr": "1 - (sum(kubelet_volume_stats_available_bytes) by (namespace, persistentvolumeclaim) / sum(kubelet_volume_stats_capacity_bytes) by (namespace, persistentvolumeclaim))",
            "legendFormat": "{{ namespace }}/{{ persistentvolumeclaim }}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 0.6 },
                { "color": "red", "value": 0.8 }
              ]
            },
            "max": 1
          }
        }
      },
      {
        "id": 8,
        "title": "Pod Distribution by Namespace",
        "type": "bargauge",
        "gridPos": { "h": 6, "w": 12, "x": 12, "y": 12 },
        "targets": [
          {
            "expr": "count by (namespace) (kube_pod_info)",
            "legendFormat": "{{ namespace }}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "displayName": "Pods"
          }
        }
      }
    ],
    "templating": {
      "list": []
    },
    "annotations": {
      "list": []
    }
  }
}
