# ===================================================================
# Docker 构建忽略文件
# ===================================================================
# 目的：减少构建上下文大小，加快构建速度，避免敏感信息泄露

# -----------------------------------------------------------------
# 版本控制
# -----------------------------------------------------------------
.git
.gitignore
.gitattributes

# -----------------------------------------------------------------
# IDE 和编辑器
# -----------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------
# 构建产物
# -----------------------------------------------------------------
dist/
build/
*.exe
*.dll
*.so
*.dylib
*.test
*.out
vendor/bin/

# -----------------------------------------------------------------
# 依赖目录
# -----------------------------------------------------------------
vendor/
node_modules/
bower_components/

# -----------------------------------------------------------------
# 文档
# -----------------------------------------------------------------
README.md
LICENSE
CHANGELOG.md
docs/
*.md

# -----------------------------------------------------------------
# 测试
# -----------------------------------------------------------------
coverage/
*.cover
htmlcov/
.tox/
.nox/

# -----------------------------------------------------------------
# 配置文件（开发环境特定）
# -----------------------------------------------------------------
.env.local
.env.*.local
*.log
logs/
tmp/

# -----------------------------------------------------------------
# 敏感文件
# -----------------------------------------------------------------
secrets/
*.pem
*.key
*.crt
credentials/

# -----------------------------------------------------------------
# CI/CD
# -----------------------------------------------------------------
.github/
.gitlab-ci.yml
.travis.yml
Jenkinsfile
azure-pipelines.yml

# -----------------------------------------------------------------
# 开发工具配置
# -----------------------------------------------------------------
.dive.log
.air.toml
Makefile
docker-compose.override.yml
