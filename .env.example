# ================================================================
# CloudNative Pipeline - 环境变量配置
# ================================================================
# 使用说明:
#   1. 复制此文件为 .env（会自动生成）
#   2. 根据需要修改下面的值
#   3. 运行 docker compose up -d 启动服务
# ================================================================
# 
# 重要: 默认密码仅用于本地开发环境！
# 生产环境请务必修改所有密码！
# ================================================================

# 应用配置
APP_PORT=8080
APP_ENV=development
APP_LOG_LEVEL=info

# 数据库配置
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_IN_PRODUCTION
DB_NAME=pipeline_db

# Redis配置
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_IN_PRODUCTION

# MinIO 配置 (对象存储)
S3_PORT=9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=CHANGE_ME_IN_PRODUCTION
S3_BUCKET=pipeline-artifacts

# Grafana 密码
GRAFANA_PASSWORD=CHANGE_ME_IN_PRODUCTION
