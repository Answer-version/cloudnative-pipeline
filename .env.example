# ================================================================
# CloudNative Pipeline - 环境变量配置
# ================================================================
# 使用说明:
#   1. 复制此文件为 .env
#   2. 根据需要修改下面的值（已有默认值，可直接使用）
#   3. 运行 docker compose up -d 启动服务
# ================================================================

# 应用配置
APP_PORT=8080
APP_ENV=development
APP_LOG_LEVEL=info

# 数据库配置
DB_USER=postgres
DB_PASSWORD=dev_password_123
DB_NAME=pipeline_db

# Redis配置
REDIS_PORT=6379
REDIS_PASSWORD=dev_password_123

# MinIO 配置 (对象存储)
S3_PORT=9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=pipeline-artifacts

# Grafana 密码
GRAFANA_PASSWORD=admin123
